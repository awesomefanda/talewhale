          "narrationPos": "bottom",
          "sceneHint": "garden",
          "bubbles": [
            { "text": "Hi! I'm Ember! Want to fly?", "x": 62, "y": 32, "tailDir": "left", "type": "normal", "speaker": "Ember" },
