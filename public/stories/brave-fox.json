          ]
        },
        {
          "layout": "wide",
          "narration": "Hoo wrapped a magical flying scarf around Finnegan — and together they soared into the night sky!",
          "narrationPos": "bottom",
          "sceneHint": "sky",
          "sfx": { "text": "WHOOSH!", "x": 72, "y": 38, "color": "#a29bfe" },
          "bubbles": [{ "text": "I can feel the whole world below!", "x": 38, "y": 30, "tailDir": "right", "type": "shout", "speaker": "Finnegan" }]
        }
      ],
      "choices": [
        { "text": "Fly to the top of the rainbow!", "next": "ch3" },
        { "text": "Explore the land above the clouds", "next": "ch3" }
